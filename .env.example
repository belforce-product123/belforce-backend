# --- Resend (transactional email; required for receipt emails on Render) ---
# Create at https://resend.com — never commit real keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# After verifying belforce.in in Resend, use e.g. BelForce <support@belforce.in>
# Testing-only default in Resend:
RESEND_FROM=BelForce <onboarding@resend.dev>
# Optional: set to false to skip startup Resend check (GET /domains; send-only keys skip automatically)
# RESEND_VERIFY_ON_STARTUP=false

# --- App (Render sets PORT automatically) ---
# PORT=5000

# --- Support line in receipt emails (shown in HTML receipt footer) ---
SUPPORT_EMAIL=support@belforce.in

# --- Admin manual receipt resend ---
# ADMIN_API_KEY=your-long-random-secret

# --- CORS (comma-separated) ---
# CORS_ORIGIN=https://belforce.in,https://www.belforce.in
